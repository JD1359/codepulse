# ── Server ────────────────────────────────────────────────
PORT=5000
CLIENT_URL=http://localhost:3000
NODE_ENV=development

# ── Database ──────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<pass>@cluster.mongodb.net/codepulse

# ── Auth ──────────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_min_32_characters_here
JWT_REFRESH_SECRET=your_refresh_secret_min_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Docker Execution ──────────────────────────────────────
# Leave empty to use local Docker daemon
DOCKER_HOST=

# Execution limits per container
EXEC_TIMEOUT_MS=10000
EXEC_MEMORY_LIMIT=50m
EXEC_CPU_LIMIT=0.5
